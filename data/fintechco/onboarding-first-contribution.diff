diff --git a/src/__tests__/validator.test.ts b/src/__tests__/validator.test.ts
index 4157ce0..ed5b510 100644
--- a/src/__tests__/validator.test.ts
+++ b/src/__tests__/validator.test.ts
@@ -30,4 +30,23 @@ describe('validatePayment', () => {
     expect(result.valid).toBe(true);
     expect(result.errors).toHaveLength(0);
   });
+
+  it('rejects when currency is missing', () => {
+    const result = validatePayment({ id: 'pay_1', amount: 50, customerId: 'cust_1' });
+    expect(result.valid).toBe(false);
+    expect(result.errors).toContain('Currency is required');
+  });
+
+  it('rejects an unsupported currency', () => {
+    const result = validatePayment({ id: 'pay_1', amount: 50, currency: 'XBT', customerId: 'cust_1' });
+    expect(result.valid).toBe(false);
+    expect(result.errors.some((e) => e.includes('Currency must be one of'))).toBe(true);
+  });
+
+  it('accepts all supported currencies', () => {
+    for (const currency of ['USD', 'EUR', 'GBP', 'CAD']) {
+      const result = validatePayment({ id: 'pay_1', amount: 50, currency, customerId: 'cust_1' });
+      expect(result.valid).toBe(true);
+    }
+  });
 });
